  [data-sound-on] .launch-intro__sound-bars i:nth-child(2) { animation-delay: -.25s; }
  [data-sound-on] .launch-intro__sound-bars i:nth-child(3) { animation-delay: -.5s; }
  .launch-intro__caption { position: absolute; left: clamp(22px, 7vw, 110px); bottom: clamp(100px, 15vh, 160px); max-width: min(680px, 76vw); text-shadow: 0 4px 34px rgba(0,0,0,.68); }
  .launch-intro__caption span { display: block; color: #77a5ff; font: 720 9px/1 ui-monospace, SFMono-Regular, Consolas, monospace; letter-spacing: .22em; text-transform: uppercase; }
  .launch-intro__caption strong { display: block; margin-top: 15px; font-size: clamp(1.8rem, 4vw, 4.6rem); font-weight: 650; line-height: 1.03; letter-spacing: -.045em; }
  .launch-intro__final { position: absolute; inset: 0; display: grid; place-content: center; padding: 24px; text-align: center; opacity: 0; transform: scale(.96); transition: opacity 1s ease, transform 1.4s cubic-bezier(.2,.8,.2,1); pointer-events: none; text-shadow: 0 5px 45px #000; }
  [data-final-visible] .launch-intro__caption { opacity: 0; transform: translateY(16px); transition: opacity .8s ease, transform .8s ease; }
  [data-final-visible] .launch-intro__final { opacity: 1; transform: scale(1); }
  .launch-intro__final span { color: rgba(170,194,246,.72); font: 700 9px/1 ui-monospace, SFMono-Regular, Consolas, monospace; letter-spacing: .3em; }
  .launch-intro__final strong { margin-top: 22px; font-size: clamp(2.6rem, 7vw, 7.2rem); line-height: .96; letter-spacing: -.065em; background: linear-gradient(105deg, #fff, #8db8ff 42%, #ae8cff 74%, #70eee4); background-clip: text; color: transparent; }

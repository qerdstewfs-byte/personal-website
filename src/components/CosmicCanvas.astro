<div class="cosmos" data-cosmos aria-hidden="true">
  <canvas class="cosmos__canvas" data-cosmos-canvas></canvas>
  <div class="cosmos__nebula cosmos__nebula--one"></div>
  <div class="cosmos__nebula cosmos__nebula--two"></div>
  <div class="cosmos__singularity">
    <span class="cosmos__gravity-ring cosmos__gravity-ring--one"></span>
    <span class="cosmos__gravity-ring cosmos__gravity-ring--two"></span>
    <span class="cosmos__gravity-ring cosmos__gravity-ring--three"></span>
    <span class="cosmos__accretion cosmos__accretion--one"></span>
    <span class="cosmos__accretion cosmos__accretion--two"></span>
    <span class="cosmos__event-horizon"></span>
  </div>
  <div class="cosmos__horizon"></div>
  <div class="cosmos__grain"></div>
  <div class="cosmos__vignette"></div>
  <span class="cosmos__coordinate cosmos__coordinate--top">INTERSTELLAR TRANSIT / SECTOR 07</span>
  <span class="cosmos__coordinate cosmos__coordinate--side">DESTINATION / BEYOND THE KNOWN</span>
  <div class="cosmos__warp-meter">
    <span>WARP</span>
    <i></i><i></i><i></i><i></i><i></i><i></i>
    <strong>ENGAGED</strong>
  </div>
</div>

<script>
  type WarpStar = {
    x: number;
    y: number;
    z: number;
    size: number;
    hue: number;
    pulse: number;
  };

  let stopCosmos: (() => void) | undefined;
  let waitingForIntro = false;

  const clearIntroWait = () => {
    document.removeEventListener("home-intro:complete", onIntroComplete);
    waitingForIntro = false;
  };

  const onIntroComplete = () => {
    clearIntroWait();
    startCosmos();
  };

  const startCosmos = () => {
    stopCosmos?.();

    const introState = document.documentElement.dataset.homeIntro;
    if (introState === "pending" || introState === "playing") {
      if (!waitingForIntro) {
        waitingForIntro = true;
        document.addEventListener("home-intro:complete", onIntroComplete, { once: true });
      }
      return;
    }

    clearIntroWait();

    const canvas = document.querySelector<HTMLCanvasElement>("[data-cosmos-canvas]");
    const cosmos = document.querySelector<HTMLElement>("[data-cosmos]");
    if (!canvas || !cosmos) return;

    const context = canvas.getContext("2d");
    if (!context) return;

    const interactionSurface = cosmos.closest<HTMLElement>(".hero--cosmic") ?? cosmos;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const compact = window.matchMedia("(max-width: 700px)").matches;
    let width = 0;
    let height = 0;
    let ratio = 1;
    let focalLength = 620;
    let maxDepth = 1400;
    let animationFrame = 0;
    let lastTime = performance.now();
    let stars: WarpStar[] = [];
    const pointer = { x: 0.5, y: 0.46, targetX: 0.5, targetY: 0.46 };

    const resetStar = (star: WarpStar, randomDepth = false) => {
      star.x = (Math.random() - 0.5) * width * 3.8;
      star.y = (Math.random() - 0.5) * height * 3.8;
      star.z = randomDepth ? 22 + Math.random() * maxDepth : maxDepth;
      star.size = 0.45 + Math.random() * 1.65;
      star.hue = Math.random() > 0.78 ? 270 : Math.random() > 0.7 ? 186 : 218;
      star.pulse = Math.random() * Math.PI * 2;
    };

    const makeStars = () => {
      const density = compact ? 108 : Math.min(210, Math.max(156, Math.round(width / 8)));
      stars = Array.from({ length: density }, () => {
        const star = { x: 0, y: 0, z: maxDepth, size: 1, hue: 218, pulse: 0 };
        resetStar(star, true);
        return star;
      });
    };

    const resize = () => {
      const bounds = cosmos.getBoundingClientRect();
      width = Math.max(1, bounds.width);
      height = Math.max(1, bounds.height);
      ratio = Math.min(window.devicePixelRatio || 1, 2);
      focalLength = Math.max(440, Math.min(760, width * 0.58));
      maxDepth = Math.max(1100, width * 1.25);
      canvas.width = Math.round(width * ratio);
      canvas.height = Math.round(height * ratio);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(ratio, 0, 0, ratio, 0, 0);
      makeStars();
    };

    const project = (star: WarpStar, depth: number) => {
      const safeDepth = Math.max(1, depth);
      const centerX = width * (0.72 + (pointer.x - 0.5) * 0.055);
      const centerY = height * (0.47 + (pointer.y - 0.5) * 0.045);
      return {
        x: centerX + (star.x / safeDepth) * focalLength,
        y: centerY + (star.y / safeDepth) * focalLength,
      };
    };

    const drawStar = (star: WarpStar, previousDepth: number, time: number, warp: number) => {
      const current = project(star, star.z);
      const previous = project(star, previousDepth + 5 + warp * 14);

      if (current.x < -160 || current.x > width + 160 || current.y < -160 || current.y > height + 160) {
        resetStar(star);
        return;
      }

      const proximity = 1 - star.z / maxDepth;
      const pulse = 0.76 + Math.sin(time * 0.002 + star.pulse) * 0.24;
      const alpha = Math.min(0.96, (0.16 + proximity * 0.9) * pulse);
      const trailScale = 1.15 + proximity * 3.6 + warp * 0.55;
      const tailX = current.x + (previous.x - current.x) * trailScale;
      const tailY = current.y + (previous.y - current.y) * trailScale;
      const gradient = context.createLinearGradient(tailX, tailY, current.x, current.y);
      gradient.addColorStop(0, `hsla(${star.hue}, 95%, 66%, 0)`);
      gradient.addColorStop(0.58, `hsla(${star.hue}, 94%, 69%, ${alpha * 0.28})`);
      gradient.addColorStop(1, `hsla(${star.hue}, 100%, 92%, ${alpha})`);

      context.strokeStyle = gradient;
      context.lineWidth = Math.min(3.4, 0.35 + proximity * 2.6 + star.size * 0.22);
      context.beginPath();
      context.moveTo(tailX, tailY);
      context.lineTo(current.x, current.y);
      context.stroke();

      if (proximity > 0.72) {
        const glowRadius = 4 + proximity * 10;
        const glow = context.createRadialGradient(current.x, current.y, 0, current.x, current.y, glowRadius);
        glow.addColorStop(0, `hsla(${star.hue}, 100%, 96%, ${alpha})`);
        glow.addColorStop(0.22, `hsla(${star.hue}, 96%, 70%, ${alpha * 0.55})`);
        glow.addColorStop(1, `hsla(${star.hue}, 90%, 60%, 0)`);
        context.fillStyle = glow;
        context.beginPath();
        context.arc(current.x, current.y, glowRadius, 0, Math.PI * 2);
        context.fill();
      }
    };

    const draw = (time: number) => {
      if (!canvas.isConnected) return;
      const delta = Math.min(34, time - lastTime || 16.7);
      lastTime = time;
      context.clearRect(0, 0, width, height);
      context.globalCompositeOperation = "lighter";
      pointer.x += (pointer.targetX - pointer.x) * 0.045;
      pointer.y += (pointer.targetY - pointer.y) * 0.045;

      const breathing = (Math.sin(time * 0.0008) + 1) * 0.5;
      const warp = reducedMotion ? 0 : 0.92 + breathing * 0.72;
      const speed = reducedMotion ? 0 : delta * (0.68 + warp * 0.46);

      stars.forEach((star) => {
        let previousDepth = star.z;
        star.z -= speed;
        if (star.z <= 1) {
          resetStar(star);
          previousDepth = star.z + speed;
        }
        drawStar(star, previousDepth, time, warp);
      });

      context.globalCompositeOperation = "source-over";
      if (!reducedMotion) animationFrame = requestAnimationFrame(draw);
    };

    const onPointerMove = (event: PointerEvent) => {
      const bounds = cosmos.getBoundingClientRect();
      pointer.targetX = Math.min(1, Math.max(0, (event.clientX - bounds.left) / bounds.width));
      pointer.targetY = Math.min(1, Math.max(0, (event.clientY - bounds.top) / bounds.height));
      cosmos.style.setProperty("--cosmos-x", `${pointer.targetX * 100}%`);
      cosmos.style.setProperty("--cosmos-y", `${pointer.targetY * 100}%`);
      interactionSurface.style.setProperty("--space-shift-x", `${(pointer.targetX - 0.5) * 22}px`);
      interactionSurface.style.setProperty("--space-shift-y", `${(pointer.targetY - 0.5) * 15}px`);
    };

    resize();
    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(cosmos);
    if (!reducedMotion) interactionSurface.addEventListener("pointermove", onPointerMove, { passive: true });
    draw(performance.now());

    stopCosmos = () => {
      cancelAnimationFrame(animationFrame);
      resizeObserver.disconnect();
      interactionSurface.removeEventListener("pointermove", onPointerMove);
      stopCosmos = undefined;
    };
  };

  document.addEventListener("astro:page-load", startCosmos);
  document.addEventListener("astro:before-swap", () => {
    stopCosmos?.();
    clearIntroWait();
  });
</script>

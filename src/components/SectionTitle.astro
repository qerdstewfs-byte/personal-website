---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="section-title">
  {eyebrow && <p class="section-title__eyebrow">{eyebrow}</p>}
  <h2 class="section-title__heading">{title}</h2>
  {description && <p class="section-title__description">{description}</p>}
</div>

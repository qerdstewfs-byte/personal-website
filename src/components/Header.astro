---
const navItems = [
  { href: "/", label: "首页" },
  { href: "/projects", label: "项目" },
  { href: "/research", label: "科研" },
  { href: "/notes", label: "学习记录" },
  { href: "/resume", label: "简历" },
  { href: "/about", label: "关于我" },
];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="site-header">
  <a href="#content" class="skip-link">跳到主要内容</a>
  <div class="site-header__inner">
    <a href="/" class="brand" aria-label="回到首页">
        <span class="brand__mark" aria-hidden="true">R</span>
        <span class="brand__text">
        <span class="brand__name">睿睿</span>
        <span class="brand__meta">Imaging · AI · Systems</span>
      </span>
    </a>

    <div class="site-header__actions">
      <button
        class="menu-toggle"
        type="button"
        aria-label="打开导航菜单"
        aria-expanded="false"
        aria-controls="primary-navigation"
        data-menu-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <nav id="primary-navigation" class="primary-nav" aria-label="主导航" data-primary-nav>
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={["primary-nav__link", { "primary-nav__link--active": isActive(item.href) }]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuButton = document.querySelector("[data-menu-toggle]");
    const primaryNav = document.querySelector("[data-primary-nav]");

    menuButton?.addEventListener("click", () => {
      const isOpen = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!isOpen));
      primaryNav?.toggleAttribute("data-open", !isOpen);
    });
  });
</script>

---
interface Props {
  title: string;
  description: string;
  tags: string[];
  status: string;
  href: string;
  disabled?: boolean;
}

const { title, description, tags, status, href, disabled = true } = Astro.props;
---

<article class="project-card">
  <div class="project-card__top">
    <span class="project-card__number">PROJECT / {title.slice(0, 2).toUpperCase()}</span>
    <span class="project-card__status">{status}</span>
  </div>
  <h3 class="project-card__title">{title}</h3>
  <p class="project-card__description">{description}</p>
  <div class="project-card__tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="project-card__footer">
    <span class="project-card__meta">{disabled ? "CASE STUDY IN PROGRESS" : "VIEW CASE STUDY"}</span>
    {disabled ? <span class="project-card__action" aria-label="详情正在整理">整理中 <span>↗</span></span> : <a href={href} class="project-card__action">查看详情 <span>↗</span></a>}
  </div>
</article>

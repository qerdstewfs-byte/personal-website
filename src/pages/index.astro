---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CosmicCanvas from "../components/CosmicCanvas.astro";

const featuredProjects = [
  {
    title: "光声成像仿真",
    description: "从信号产生、传播到图像重建，搭建可复现的仿真实验，理解成像机理并验证算法。",
    tags: ["Photoacoustic", "MATLAB", "Python"],
    status: "学习推进中",
    href: "/projects/photoacoustic-simulation",
  },
  {
    title: "Qt 上位机开发",
    description: "将设备通信、实时数据、参数控制和实验流程整合进可靠、清晰的桌面工程界面。",
    tags: ["Qt", "C++", "Serial"],
    status: "持续完善",
    href: "/projects/qt-control-panel",
  },
  {
    title: "树莓派视觉系统",
    description: "面向真实硬件环境，完成视觉采集、图像处理与轻量模型部署的端到端验证。",
    tags: ["Raspberry Pi", "OpenCV", "Linux"],
    status: "原型阶段",
    href: "/projects/raspberry-pi-vision",
  },
];

const interests = ["医学影像", "光声成像", "深度学习", "嵌入式视觉"];
const techStack = ["Python", "PyTorch", "OpenCV", "Qt / C++", "Linux", "Astro", "Tailwind CSS"];
const learningTopics = ["医学影像基础", "图像重建方法", "PyTorch 实验流程", "嵌入式视觉部署"];
const tickerItems = ["Medical Imaging", "Photoacoustic", "Deep Learning", "Computer Vision", "Embedded Systems", "Engineering UI"];
---

<BaseLayout
  title="睿睿 | 医学影像 · AI · 工程系统"
  description="睿睿的个人学术技术主页，探索医学影像、光声成像、深度学习、嵌入式视觉和工程软件。"
>
  <section class="hero hero--cosmic">
    <CosmicCanvas />
    <div class="cosmic-beacon" aria-hidden="true">
      <span class="cosmic-beacon__pulse"></span>
      <span>FUTURE VOYAGE / ONLINE</span>
    </div>
    <div class="page-frame hero__grid">
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Imaging the unseen · Building the future</p>
        <h1 class="hero__title">从微小的信号出发，<span class="gradient-text">奔赴更辽阔的星辰大海。</span></h1>
        <p class="hero__lead">
          你好，我是睿睿。以医学影像与智能系统为坐标，把每一次实验变成通往未知的航标——用算法看见更深处，也用工程拓宽未来可以抵达的边界。
        </p>
        <div class="hero__actions">
          <a href="/projects" class="button-primary">探索项目 <span class="button-arrow">→</span></a>
          <a href="/resume" class="button-secondary">查看简历 <span class="button-arrow">↗</span></a>
        </div>
        <div class="hero-telemetry" aria-label="研究状态概览">
          <div><strong>04</strong><span>ACTIVE DOMAINS</span></div>
          <div><strong>∞</strong><span>EXPLORATION RANGE</span></div>
          <div><strong>01</strong><span>FUTURE VOYAGE</span></div>
        </div>
      </div>

      <div class="hero-visual hero-visual--cosmic" data-reveal data-reveal-delay="1" aria-label="睿睿的个人研究视觉名片">
        <div class="hero-visual__halo"></div>
        <div class="hero-visual__orbit hero-visual__orbit--outer"></div>
        <div class="hero-visual__orbit hero-visual__orbit--middle"></div>
        <div class="hero-visual__orbit hero-visual__orbit--inner"></div>
        <div class="orbit-label orbit-label--one">IMAGING / 01</div>
        <div class="orbit-label orbit-label--two">NEURAL / 02</div>
        <div class="orbit-crosshair" aria-hidden="true"><span></span><span></span></div>
        <div class="hero-visual__portrait">
          <img src="/avatar.png" alt="睿睿的头像" width="700" height="814" />
          <div class="portrait-caption">
            <strong>睿睿</strong>
            <span>Imaging · AI · Systems</span>
          </div>
        </div>
        <div class="float-chip float-chip--one">
          <span class="float-chip__label">Current focus</span>
          <span class="float-chip__value"><span class="status-dot"></span> 光声成像</span>
        </div>
        <div class="float-chip float-chip--two">
          <span class="float-chip__label">Next destination</span>
          <span class="float-chip__value"><span class="status-dot"></span> 星辰大海</span>
        </div>
        <div class="hero-visual__signal" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
    </div>
    <div class="cosmic-manifesto" aria-hidden="true">
      <span>探索未知，是我们共同的航向</span>
      <i></i>
      <strong>TO THE VAST UNKNOWN</strong>
    </div>
  </section>

  <div class="signal-strip" aria-hidden="true">
    <div class="signal-strip__track">
      {[...tickerItems, ...tickerItems].map((item) => <span class="signal-strip__item">{item}</span>)}
    </div>
  </div>

  <section class="section-block">
    <div class="page-frame">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-kicker">01 / Research lens</p>
          <h2 class="section-heading">从成像原理到真实设备，<br />关注完整链路。</h2>
        </div>
      </div>
      <div class="interest-panel" data-reveal data-reveal-delay="1">
        <article class="glass-card interest-intro">
          <span class="interest-intro__index">RESEARCH / 2026</span>
          <h3>连接科学问题<br />与工程实现</h3>
          <p>从信号、图像和模型出发，最终落在可以验证、可以复现、也可以长期演进的系统上。</p>
        </article>
        <div class="glass-card interest-map">
          {interests.map((item, index) => (
            <div class="interest-item">
              <span>0{index + 1} / FIELD</span>
              <strong>{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-block section-block--compact">
    <div class="page-frame">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-kicker">02 / Selected work</p>
          <h2 class="section-heading">正在发生的项目。</h2>
          <p class="section-copy">不是静态陈列，而是持续推进的实验、原型与工程记录。</p>
        </div>
        <a href="/projects" class="text-link">查看全部项目 <span>↗</span></a>
      </div>
      <div class="cards-grid">
        {featuredProjects.map((project, index) => <div data-reveal data-reveal-delay={index === 0 ? undefined : String(Math.min(index, 2))}><ProjectCard {...project} /></div>)}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="page-frame split-grid">
      <article class="content-card" data-reveal>
        <p class="section-kicker">03 / Toolset</p>
        <h3>技术栈</h3>
        <div class="stack-cloud">
          {techStack.map((item) => <span class="stack-pill">{item}</span>)}
        </div>
      </article>
      <article class="content-card" data-reveal data-reveal-delay="1">
        <p class="section-kicker">04 / Now learning</p>
        <h3>最近学习方向</h3>
        <ol class="learning-list">
          {learningTopics.map((item) => <li>{item}</li>)}
        </ol>
      </article>
    </div>
  </section>

  <section class="section-block section-block--compact">
    <div class="page-frame">
      <article class="glass-card cta-card" data-reveal>
        <div>
          <p class="section-kicker">Build something meaningful</p>
          <h2>对研究、项目或工程实践<br />有共同兴趣？</h2>
          <p>欢迎交流医学影像、视觉系统与科研工程化。当前邮箱为占位信息，可随时替换为正式联系方式。</p>
        </div>
        <a href="mailto:example@example.com" class="button-primary">发一封邮件 <span class="button-arrow">↗</span></a>
      </article>
    </div>
  </section>
</BaseLayout>

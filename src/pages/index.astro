---
import BaseLayout from "../layouts/BaseLayout.astro";

const focusAreas = ["光声效应", "声波传播", "数据采集", "图像重建"];
const tickerItems = ["Photoacoustic Imaging", "Optical Absorption", "Acoustic Propagation", "Signal Acquisition", "Image Reconstruction"];
---

<BaseLayout
  title="睿睿 | 光声成像"
  description="睿睿的个人主页，聚焦光声成像的物理原理、信号采集、仿真与图像重建。"
>
  <section class="hero">
    <div class="page-frame hero__grid">
      <div class="hero__content" data-reveal>
        <p class="eyebrow">Photoacoustic Imaging · Learning · Practice</p>
        <h1 class="hero__title">从光与声的交汇处，<span class="gradient-text">看见更深层的信息。</span></h1>
        <p class="hero__lead">
          你好，我是睿睿。这里聚焦光声成像：从光能吸收、热弹性膨胀与声波传播，到传感器采样和图像重建，逐步理解完整成像链路。
        </p>
        <div class="hero__actions">
          <a href="/photoacoustic" class="button-primary">了解光声成像 <span class="button-arrow">→</span></a>
          <a href="/about" class="button-secondary">关于我 <span class="button-arrow">↗</span></a>
        </div>
      </div>

      <div class="hero-visual" data-reveal data-reveal-delay="1" aria-label="睿睿的个人研究视觉名片">
        <div class="hero-visual__halo"></div>
        <div class="hero-visual__orbit"></div>
        <div class="hero-visual__portrait">
          <img src="/avatar.png" alt="睿睿的头像" width="700" height="814" />
          <div class="portrait-caption">
            <strong>睿睿</strong>
            <span>Photoacoustic Imaging</span>
          </div>
        </div>
        <div class="float-chip float-chip--one">
          <span class="float-chip__label">Current focus</span>
          <span class="float-chip__value"><span class="status-dot"></span> 光声成像</span>
        </div>
        <div class="float-chip float-chip--two">
          <span class="float-chip__label">Imaging chain</span>
          <span class="float-chip__value"><span class="status-dot"></span> Light → Sound</span>
        </div>
      </div>
    </div>
  </section>

  <div class="signal-strip" aria-hidden="true">
    <div class="signal-strip__track">
      {[...tickerItems, ...tickerItems].map((item) => <span class="signal-strip__item">{item}</span>)}
    </div>
  </div>

  <section class="section-block">
    <div class="page-frame">
      <div class="section-head" data-reveal>
        <div>
          <p class="section-kicker">01 / Imaging chain</p>
          <h2 class="section-heading">理解每一步，<br />才能看清完整图像。</h2>
        </div>
      </div>
      <div class="interest-panel" data-reveal data-reveal-delay="1">
        <article class="glass-card interest-intro">
          <span class="interest-intro__index">PHOTOACOUSTIC / FOCUS</span>
          <h3>连接物理机制<br />与成像结果</h3>
          <p>光声成像把光学吸收对比度转化为可探测的超声信号，为组织结构与功能信息提供独特的观察窗口。</p>
        </article>
        <div class="glass-card interest-map">
          {focusAreas.map((item, index) => (
            <div class="interest-item">
              <span>0{index + 1} / STAGE</span>
              <strong>{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-block section-block--compact">
    <div class="page-frame">
      <article class="glass-card cta-card" data-reveal>
        <div>
          <p class="section-kicker">Explore the modality</p>
          <h2>从原理开始，<br />走进光声成像。</h2>
          <p>查看光声成像页面，了解它如何把光学激发转化为声学信号，以及信号如何进一步形成图像。</p>
        </div>
        <a href="/photoacoustic" class="button-primary">开始了解 <span class="button-arrow">↗</span></a>
      </article>
    </div>
  </section>
</BaseLayout>

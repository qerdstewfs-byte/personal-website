---
import BaseLayout from "../layouts/BaseLayout.astro";

const focusPoints = [
  {
    title: "成像原理",
    description: "光声效应、激光激发与超声信号产生的物理机制。",
  },
  {
    title: "图像重建",
    description: "从延时叠加、反投影到基于模型和深度学习的重建方法。",
  },
  {
    title: "仿真实验",
    description: "基于 k-Wave 等工具的正向仿真与重建算法验证。",
  },
];
---

<BaseLayout
  title="睿睿 | 光声成像（PAI）"
  description="睿睿的个人主页，专注光声成像（Photoacoustic Imaging, PAI）方向的学习与研究。"
>
  <section class="space-y-7">
    <div class="space-y-4">
      <p class="text-sm font-medium uppercase text-zinc-500 dark:text-zinc-400">Photoacoustic Imaging</p>
      <h1 class="text-4xl font-semibold tracking-normal text-zinc-950 dark:text-zinc-50 sm:text-5xl">光声成像（PAI）</h1>
      <p class="max-w-3xl text-xl leading-9 text-zinc-700 dark:text-zinc-200">
        你好，我是睿睿。我目前专注于光声成像方向，这里记录我在成像原理、图像重建和仿真实验方面的学习与研究。
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/pai" class="rounded-md bg-zinc-950 px-5 py-3 text-sm font-medium text-white no-underline hover:bg-zinc-800 dark:bg-zinc-50 dark:text-zinc-950 dark:hover:bg-zinc-200">进入光声成像</a>
    </div>
  </section>

  <section class="mt-16 space-y-6">
    <h2 class="text-2xl font-semibold">当前关注</h2>
    <div class="grid gap-5 md:grid-cols-3">
      {
        focusPoints.map((point) => (
          <div class="rounded-lg border border-zinc-200 p-6 dark:border-zinc-800">
            <h3 class="text-lg font-semibold">{point.title}</h3>
            <p class="mt-2 leading-7 text-zinc-600 dark:text-zinc-300">{point.description}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

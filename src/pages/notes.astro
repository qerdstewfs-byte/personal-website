---
import BaseLayout from "../layouts/BaseLayout.astro";
const categories = [
  { title: "高等数学", description: "整理极限、微积分、级数和多元函数，为信号处理、优化与成像算法打下基础。" },
  { title: "线性代数", description: "记录矩阵、向量空间、特征值和分解方法，连接图像处理、深度学习与数值计算。" },
  { title: "信号与系统", description: "梳理卷积、傅里叶变换、系统响应和采样，服务于成像信号理解与重建方法学习。" },
  { title: "PyTorch", description: "沉淀模型搭建、训练循环、数据加载、可视化分析与实验复现相关笔记。" },
  { title: "Qt", description: "记录界面布局、信号槽、串口通信、线程处理与上位机工程结构。" },
  { title: "医学影像", description: "整理不同影像模态、图像质量、标注方式与常见分析任务的基础认识。" },
  { title: "嵌入式开发", description: "记录 Linux 环境、开发板调试、摄像头接入、模型部署与边缘端运行问题。" },
];
---
<BaseLayout title="学习记录 | 睿睿" description="睿睿的分类式学习记录入口，包含数学、信号、PyTorch、Qt、医学影像和嵌入式开发。">
  <section class="page-hero">
    <div class="page-frame" data-reveal>
      <p class="eyebrow">Notes · Knowledge · Growth</p>
      <h1 class="page-hero__title">把模糊的理解，<br /><span class="gradient-text">沉淀成清晰的知识。</span></h1>
      <p class="page-hero__copy">不是按时间消逝的博客流，而是一张持续生长的知识地图。每一个主题都会逐步扩展为文章、实验记录与阅读笔记。</p>
    </div>
  </section>
  <section class="page-content">
    <div class="page-frame cards-grid">
      {categories.map((category, index) => (
        <article class="topic-card" data-reveal data-reveal-delay={String(index % 3)}>
          <span class="topic-card__index">0{index + 1} / KNOWLEDGE</span>
          <h2>{category.title}</h2>
          <p>{category.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

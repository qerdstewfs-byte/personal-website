---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "光声成像仿真",
    description: "搭建光声成像基础仿真流程，记录声压信号、传感器采样、重建算法和实验参数之间的关系，为后续科研学习提供可复现实验入口。",
    tags: ["Photoacoustic", "Image Reconstruction", "Python", "MATLAB"],
    status: "学习推进中",
    href: "/projects/photoacoustic-simulation",
  },
  {
    title: "Qt 上位机开发",
    description: "面向实验控制和设备调试场景，整理 Qt 界面、串口通信、数据显示、参数配置和日志记录等功能模块。",
    tags: ["Qt", "C++", "Serial", "GUI"],
    status: "持续完善",
    href: "/projects/qt-control-panel",
  },
  {
    title: "树莓派视觉系统",
    description: "使用树莓派完成图像采集、基础图像处理和轻量模型部署尝试，重点关注真实硬件环境下的稳定运行。",
    tags: ["Raspberry Pi", "OpenCV", "Linux", "Camera"],
    status: "原型阶段",
    href: "/projects/raspberry-pi-vision",
  },
  {
    title: "K230 嵌入式视觉识别",
    description: "围绕 K230 平台进行嵌入式视觉识别实验，关注模型转换、端侧推理、摄像头输入和结果显示流程。",
    tags: ["K230", "Embedded AI", "Vision", "Inference"],
    status: "调研与实验",
    href: "/projects/k230-vision",
  },
  {
    title: "PyTorch 深度学习实验",
    description: "记录 PyTorch 模型训练、数据集处理、可视化分析和实验复现过程，用于沉淀深度学习基础能力。",
    tags: ["PyTorch", "Deep Learning", "Python", "Experiment"],
    status: "长期积累",
    href: "/projects/pytorch-experiments",
  },
];
---

<BaseLayout title="项目 | 睿睿" description="睿睿的项目展示，包含光声成像仿真、Qt 上位机、树莓派视觉、K230 视觉识别和 PyTorch 实验。">
  <section class="space-y-4">
    <p class="text-sm font-medium uppercase text-zinc-500 dark:text-zinc-400">Projects</p>
    <h1 class="text-4xl font-semibold">项目展示</h1>
    <p class="max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300">
      这里整理正在学习、实践和逐步完善的项目。当前版本先展示项目方向、技术栈和状态，详情页路径已经预留，后续可以继续扩展为完整案例。
    </p>
  </section>

  <section class="mt-10 grid gap-5 md:grid-cols-2">
    {projects.map((project) => <ProjectCard {...project} />)}
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  { title: "光声成像仿真", description: "搭建光声成像基础仿真流程，记录声压信号、传感器采样、重建算法和实验参数之间的关系，为后续科研学习提供可复现实验入口。", tags: ["Photoacoustic", "Image Reconstruction", "Python", "MATLAB"], status: "学习推进中", href: "/projects/photoacoustic-simulation" },
  { title: "Qt 上位机开发", description: "面向实验控制和设备调试场景，整理 Qt 界面、串口通信、数据显示、参数配置和日志记录等功能模块。", tags: ["Qt", "C++", "Serial", "GUI"], status: "持续完善", href: "/projects/qt-control-panel" },
  { title: "树莓派视觉系统", description: "使用树莓派完成图像采集、基础图像处理和轻量模型部署尝试，重点关注真实硬件环境下的稳定运行。", tags: ["Raspberry Pi", "OpenCV", "Linux", "Camera"], status: "原型阶段", href: "/projects/raspberry-pi-vision" },
  { title: "K230 嵌入式视觉识别", description: "围绕 K230 平台进行嵌入式视觉识别实验，关注模型转换、端侧推理、摄像头输入和结果显示流程。", tags: ["K230", "Embedded AI", "Vision", "Inference"], status: "调研与实验", href: "/projects/k230-vision" },
  { title: "PyTorch 深度学习实验", description: "记录 PyTorch 模型训练、数据集处理、可视化分析和实验复现过程，用于沉淀深度学习基础能力。", tags: ["PyTorch", "Deep Learning", "Python", "Experiment"], status: "长期积累", href: "/projects/pytorch-experiments" },
];
---

<BaseLayout title="项目 | 睿睿" description="睿睿的项目展示，包含光声成像仿真、Qt 上位机、树莓派视觉、K230 视觉识别和 PyTorch 实验。">
  <section class="page-hero">
    <div class="page-frame" data-reveal>
      <p class="eyebrow">Projects · Experiments · Systems</p>
      <h1 class="page-hero__title">把问题变成实验，<br /><span class="gradient-text">再把实验变成系统。</span></h1>
      <p class="page-hero__copy">这里记录正在学习、实践与持续完善的项目。从研究型仿真到真实硬件原型，每一个项目都关注过程是否清晰、结果是否可复现。</p>
    </div>
  </section>
  <section class="page-content">
    <div class="page-frame cards-grid cards-grid--two">
      {projects.map((project, index) => <div data-reveal data-reveal-delay={String(index % 2)}><ProjectCard {...project} /></div>)}
    </div>
  </section>
</BaseLayout>

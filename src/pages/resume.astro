---
import BaseLayout from "../layouts/BaseLayout.astro";

const researchAreas = ["医学影像", "光声成像", "图像重建", "深度学习", "嵌入式视觉"];
const skills = ["Python", "PyTorch", "OpenCV", "Qt / C++", "Linux", "Git", "Astro / Tailwind CSS"];
const projectExperience = [
  "光声成像仿真：学习成像流程、采样方式和图像重建基础实验。",
  "Qt 上位机开发：整理设备通信、参数配置、图像显示和日志记录等工程功能。",
  "嵌入式视觉系统：尝试在树莓派与 K230 等平台上完成视觉采集和端侧推理。",
];
---

<BaseLayout title="简历 | 睿睿" description="睿睿的公开简历页面，展示教育经历、研究方向、技能栈和项目经历。">
  <section class="space-y-4">
    <p class="text-sm font-medium uppercase text-zinc-500 dark:text-zinc-400">Resume</p>
    <h1 class="text-4xl font-semibold">简历</h1>
    <p class="max-w-3xl text-lg leading-8 text-zinc-600 dark:text-zinc-300">
      这是公开展示版本的简历页面，仅保留适合个人主页展示的信息。详细经历、成绩单、证件信息和私人联系方式不会在这里直接公开。
    </p>
    <a href="/resume.pdf" class="inline-flex rounded-md bg-zinc-950 px-5 py-3 text-sm font-medium text-white no-underline hover:bg-zinc-800 dark:bg-zinc-50 dark:text-zinc-950 dark:hover:bg-zinc-200">下载 PDF 简历</a>
  </section>

  <section class="mt-10 grid gap-5">
    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">基本介绍</h2>
      <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
        我是睿睿，目前正在围绕 AI、医学影像、嵌入式视觉和工程软件开发持续学习与实践，希望把科研问题和可运行的工程项目结合起来。
      </p>
    </article>

    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">教育经历</h2>
      <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
        研究生阶段相关学习经历待补充。后续可以加入学校、专业、研究方向、导师课题组或公开可展示的课程与科研训练信息。
      </p>
    </article>

    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">研究方向</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {researchAreas.map((item) => <span class="rounded-full bg-zinc-100 px-4 py-2 text-sm text-zinc-700 dark:bg-zinc-900 dark:text-zinc-300">{item}</span>)}
      </div>
    </article>

    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">技能栈</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {skills.map((item) => <span class="rounded-full border border-zinc-200 px-4 py-2 text-sm text-zinc-700 dark:border-zinc-800 dark:text-zinc-300">{item}</span>)}
      </div>
    </article>

    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">项目经历</h2>
      <ul class="mt-4 space-y-3 text-zinc-600 dark:text-zinc-300">
        {projectExperience.map((item) => <li class="leading-7">{item}</li>)}
      </ul>
    </article>

    <article class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
      <h2 class="text-2xl font-semibold">联系方式</h2>
      <p class="mt-3 leading-7 text-zinc-600 dark:text-zinc-300">
        邮箱：<a href="mailto:example@example.com">example@example.com</a>
      </p>
    </article>
  </section>
</BaseLayout>

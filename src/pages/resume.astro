---
import BaseLayout from "../layouts/BaseLayout.astro";
const researchAreas = ["医学影像", "光声成像", "图像重建", "深度学习", "嵌入式视觉"];
const skills = ["Python", "PyTorch", "OpenCV", "Qt / C++", "Linux", "Git", "Astro / Tailwind CSS"];
const projectExperience = [
  "光声成像仿真：学习成像流程、采样方式和图像重建基础实验。",
  "Qt 上位机开发：整理设备通信、参数配置、图像显示和日志记录等工程功能。",
  "嵌入式视觉系统：尝试在树莓派与 K230 等平台上完成视觉采集和端侧推理。",
];
---
<BaseLayout title="简历 | 睿睿" description="睿睿的公开简历页面，展示教育经历、研究方向、技能栈和项目经历。">
  <section class="page-hero">
    <div class="page-frame" data-reveal>
      <p class="eyebrow">Resume · Capabilities · Experience</p>
      <h1 class="page-hero__title">研究与工程能力，<br /><span class="gradient-text">一页清晰呈现。</span></h1>
      <p class="page-hero__copy">公开展示版本仅保留适合个人主页的信息。详细经历、证件信息与私人联系方式不会直接公开。</p>
      <div class="hero__actions"><a href="/resume.pdf" class="button-primary">下载 PDF 简历 <span class="button-arrow">↓</span></a></div>
    </div>
  </section>
  <section class="page-content">
    <div class="page-frame resume-stack">
      <article class="content-card resume-card" data-reveal>
        <p class="section-kicker">01 / Profile</p><h2>基本介绍</h2>
        <p>我是睿睿，正在围绕 AI、医学影像、嵌入式视觉和工程软件开发持续学习与实践，希望把科研问题与可运行的工程项目结合起来。</p>
      </article>
      <article class="content-card resume-card" data-reveal>
        <p class="section-kicker">02 / Education</p><h2>教育经历</h2>
        <p>研究生阶段相关学习经历待补充。后续可以加入学校、专业、研究方向、导师课题组或公开可展示的课程与科研训练信息。</p>
      </article>
      <div class="split-grid">
        <article class="content-card resume-card" data-reveal>
          <p class="section-kicker">03 / Research</p><h2>研究方向</h2>
          <div class="stack-cloud">{researchAreas.map((item) => <span class="stack-pill">{item}</span>)}</div>
        </article>
        <article class="content-card resume-card" data-reveal data-reveal-delay="1">
          <p class="section-kicker">04 / Skills</p><h2>技能栈</h2>
          <div class="stack-cloud">{skills.map((item) => <span class="stack-pill">{item}</span>)}</div>
        </article>
      </div>
      <article class="content-card resume-card" data-reveal>
        <p class="section-kicker">05 / Experience</p><h2>项目经历</h2>
        <ul>{projectExperience.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="glass-card cta-card" data-reveal>
        <div><p class="section-kicker">06 / Contact</p><h2>保持联系。</h2><p>当前使用公开占位邮箱，可替换为正式的学术或工作邮箱。</p></div>
        <a href="mailto:example@example.com" class="button-secondary">example@example.com <span class="button-arrow">↗</span></a>
      </article>
    </div>
  </section>
</BaseLayout>
